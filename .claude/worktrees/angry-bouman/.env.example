# Exemple de configuration — remplacez par vos vraies valeurs en local

# Telegram
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_CHAT_ID=YOUR_TELEGRAM_USER_ID

# Fees
FEES_WALLET=0xYourFeesWalletAddress
PLATFORM_FEE_RATE=0.01

# Crypto
ENCRYPTION_KEY=CHANGE_ME_GENERATED_KEY

# Monitoring
MONITOR_POLL_INTERVAL=15

# Polygon / Web3
# URL RPC Polygon (ex : Alchemy, QuickNode, Ankr…)
# Exemple : https://polygon-mainnet.g.alchemy.com/v2/VOTRE_CLE
POLYGON_RPC_URL=

# DB & Redis
DB_URL=postgresql+asyncpg://polybot:polybot_dev@db:5432/polybot
REDIS_URL=redis://redis:6379

# Bridge (optional)
LIFI_API_KEY=your_lifi_api_key
ACROSS_API_URL=https://across.to/api
BRIDGE_SLIPPAGE=0.005

# Fiat on-ramp (optional - Transak)
TRANSAK_API_KEY=your_transak_api_key

# Execution tuning
MAX_CONCURRENT_TRADES=20
COLLECT_FEES_ONCHAIN=false

# UI / Branding
# (optionnel) URL d'une image bannière à afficher dans le message /start
WELCOME_BANNER_URL=
