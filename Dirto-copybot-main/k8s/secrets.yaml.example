# =============================================================================
# WenBot Kubernetes Secrets
# =============================================================================
# WARNING: NE JAMAIS COMMITTER ce fichier avec de vraies valeurs !
#
# Usage:
#   1. Copier ce fichier: cp secrets.yaml.example secrets.yaml
#   2. Remplacer les valeurs placeholder par vos vraies valeurs encodees en base64
#   3. Pour encoder en base64: echo -n "votre_valeur" | base64
#   4. Appliquer: kubectl apply -f secrets.yaml
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: wenbot-secrets
  namespace: wenbot-prod
type: Opaque
data:
  # Telegram
  # echo -n "your_telegram_bot_token" | base64
  TELEGRAM_TOKEN: eW91cl90ZWxlZ3JhbV9ib3RfdG9rZW4=

  # Supabase
  # echo -n "https://xxx.supabase.co" | base64
  SUPABASE_URL: aHR0cHM6Ly94eHguc3VwYWJhc2UuY28=
  # echo -n "eyJ..." | base64
  SUPABASE_KEY: ZXlKLi4u

  # Redis
  # echo -n "redis://redis.wenbot-prod.svc.cluster.local:6379" | base64
  REDIS_URL: cmVkaXM6Ly9yZWRpcy53ZW5ib3QtcHJvZC5zdmMuY2x1c3Rlci5sb2NhbDo2Mzc5

  # Blockchain
  # echo -n "https://polygon-rpc.com" | base64
  POLYGON_RPC_URL: aHR0cHM6Ly9wb2x5Z29uLXJwYy5jb20=
  # echo -n "https://polygon-mainnet.g.alchemy.com/v2/your_key" | base64
  ALCHEMY_RPC_URL: aHR0cHM6Ly9wb2x5Z29uLW1haW5uZXQuZy5hbGNoZW15LmNvbS92Mi95b3VyX2tleQ==
  # echo -n "0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174" | base64
  USDC_CONTRACT: MHgyNzkxQmNhMWYyZGU0NjYxRUQ4OEEzMEM5OUE3YTk0NDlBYTg0MTc0

  # WenBot wallet
  # echo -n "0x...your_fee_wallet_address" | base64
  WENBOT_FEE_WALLET: MHguLi55b3VyX2ZlZV93YWxsZXRfYWRkcmVzcw==
  # echo -n "0x...your_fee_wallet_pk" | base64
  WENBOT_PRIVATE_KEY: MHguLi55b3VyX2ZlZV93YWxsZXRfcGs=

  # Encryption
  # echo -n "64_hex_chars_here" | base64
  ENCRYPTION_MASTER_KEY: NjRfaGV4X2NoYXJzX2hlcmU=

  # Polymarket
  # echo -n "https://clob.polymarket.com" | base64
  POLYMARKET_CLOB_HOST: aHR0cHM6Ly9jbG9iLnBvbHltYXJrZXQuY29t
  # echo -n "137" | base64
  POLYMARKET_CHAIN_ID: MTM3
