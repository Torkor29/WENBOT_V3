# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
ADMIN_CHAT_ID=your_admin_chat_id

# Fees
FEES_WALLET=0xYourFeesWalletAddress
PLATFORM_FEE_RATE=0.01

# Crypto
ENCRYPTION_KEY=your_32_byte_hex_key

# Monitoring
MONITOR_POLL_INTERVAL=15

# DB & Redis
DB_URL=postgresql+asyncpg://user:pass@db:5432/polybot
REDIS_URL=redis://redis:6379

# Bridge (optional)
LIFI_API_KEY=your_lifi_api_key
ACROSS_API_URL=https://across.to/api
BRIDGE_SLIPPAGE=0.005

# Fiat on-ramp (optional - Transak)
TRANSAK_API_KEY=your_transak_api_key
