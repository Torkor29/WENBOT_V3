# ============================================================
# WENBOT FUSION — Copy Wallet + Strategy Following
# Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL values below
#   3. NEVER commit .env to git — it contains secrets!
#
#   Generate encryption key:
#     python -c "import secrets; print(secrets.token_hex(32))"
#
#   Get Telegram bot token:
#     @BotFather → /newbot → copy token
#
#   Get your Telegram ID:
#     @userinfobot → /start → copy ID
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
# New bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID (for /admin access)
ADMIN_CHAT_ID=your_admin_chat_id_here

# ── Security ─────────────────────────────────────────────────
# AES-256 encryption key (64 hex chars) — MUST be unique per deployment
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=generate_a_new_key_see_instructions_above

# ── Database ─────────────────────────────────────────────────
# PostgreSQL (docker-compose uses these defaults)
POSTGRES_PASSWORD=polybot_change_me
DB_URL=postgresql+asyncpg://polybot:polybot_change_me@db:5432/polybot

# ── Redis ────────────────────────────────────────────────────
# Used for: rate limiting + strategy signal pub/sub
REDIS_URL=redis://redis:6379
# Strategy listener also uses this Redis for signals:* subscription
STRATEGY_REDIS_URL=redis://redis:6379

# ── Blockchain (Polygon) ────────────────────────────────────
# RPC endpoint — Alchemy, QuickNode, Ankr, etc.
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# Optional: WebSocket for L2 event listening
POLYGON_WSS_URL=
ENABLE_L2_BLOCKCHAIN=false

# ── Fees — Copy Wallet ──────────────────────────────────────
# Wallet that receives platform fees (Polygon address)
FEES_WALLET=0xYourFeesWalletAddress
# Fee rate per copy trade (0.01 = 1%)
PLATFORM_FEE_RATE=0.01
# Actually transfer fees on-chain (false = record only, no transfer)
COLLECT_FEES_ONCHAIN=false

# ── Strategy Engine ─────────────────────────────────────────
# Delay between subscriber executions (ms)
STRATEGY_EXECUTION_DELAY_MS=100
# Resolver poll interval (seconds) — checks market resolution
STRATEGY_RESOLVER_INTERVAL=30
# Performance fee rate (0.05 = 5% of daily positive PnL)
STRATEGY_PERF_FEE_RATE=0.05
# Trade fee bounds (per-user configurable within these limits)
STRATEGY_MIN_TRADE_FEE_RATE=0.01
STRATEGY_MAX_TRADE_FEE_RATE=0.20

# ── MATIC Gas — Strategy Wallets ────────────────────────────
# Anti-exploit limits for automatic MATIC refills
STRATEGY_MATIC_REFILL_AMOUNT=0.1
STRATEGY_MATIC_MIN_BALANCE=0.01
STRATEGY_MATIC_MAX_REFILLS=3
STRATEGY_MATIC_MAX_TOTAL=0.3
STRATEGY_MATIC_COOLDOWN_SECONDS=86400
STRATEGY_MIN_USDC_FOR_REFILL=2.0

# ── Monitoring — Copy Wallet ────────────────────────────────
# Wallet activity polling interval (seconds) — lower = faster copy.
# Depuis le refactor activity-based (2026-04), le monitor appelle
# /activity UNIQUEMENT quand il y a des nouveaux trades, donc 1s ne
# coûte quasi rien en idle. À laisser à 1 pour du scalping 5min.
MONITOR_POLL_INTERVAL=1
# Max parallel trade executions
MAX_CONCURRENT_TRADES=20


# ── Dashboard (optional) ────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8080
DASHBOARD_URL=

# ── Mini App (Telegram WebApp) ──────────────────────────────
# Public HTTPS URL serving the mini app (required for WebApp button)
# Ex: https://bot.mondomaine.com/miniapp
MINIAPP_URL=

# ── UI / Branding ────────────────────────────────────────────
# Banner image URL for /start welcome message (optional)
WELCOME_BANNER_URL=

# ── Telegram Group Topics (auto-filled by bot on group setup) ─
# Leave empty — the bot creates topics automatically when added as admin
GROUP_CHAT_ID=
TOPIC_SIGNALS_ID=0
TOPIC_TRADERS_ID=0
TOPIC_PORTFOLIO_ID=0
TOPIC_ALERTS_ID=0
TOPIC_ADMIN_ID=0
